# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=afyacall
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=afyacall_db

# ─── Database ─────────────────────────────────────────────────────────────────
# Used by Prisma CLI on the host (docker-compose constructs this from POSTGRES_* vars internally)
DATABASE_URL="postgresql://afyacall:change_me_strong_password@postgres:5432/afyacall_db?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-strong-random-secret"
AUTH_SECRET="generate-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Daily.co ─────────────────────────────────────────────────────────────────
DAILY_API_KEY="your-daily-co-api-key"
DAILY_DOMAIN="your-subdomain.daily.co"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
NODE_ENV="development"
